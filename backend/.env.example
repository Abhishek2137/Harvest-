# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True

# Neodb (Neon PostgreSQL) Database Configuration
NEON_DATABASE=your_database_name
NEON_USER=your_database_user
NEON_PASSWORD=your_database_password
NEON_HOST=your-database-host.neon.tech
NEON_PORT=5432

# Alternative: Local PostgreSQL (if not using Neodb)
DB_NAME=harvest_db
DB_USER=postgres
DB_PASSWORD=your_local_password
DB_HOST=localhost
DB_PORT=5432

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
